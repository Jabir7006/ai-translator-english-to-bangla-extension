{
  "manifest_version": 3,
  "name": "AI Text Translator",
  "version": "1.6",
  "permissions": ["storage"],
  "options_page": "options.html",
  "host_permissions": ["*://api.groq.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Translate Text"
  }
}